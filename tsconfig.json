{
	"compilerOptions": {
		"baseUrl": ".",
		"target": "ES2021",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["DOM", "ES2021"],
		"types": ["node"],
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowJs": true,
		"importHelpers": false
	},
	"include": ["src/**/*.ts"]
}

{
	"name": "obsidian-ccc-search",
	"version": "0.1.0",
	"description": "Semantic search of your Obsidian vault via ccc (cocoindex-code).",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"check": "tsc -noEmit -skipLibCheck"
	},
	"keywords": ["obsidian", "semantic-search", "cocoindex"],
	"author": "Jun Zhou",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.24.0",
		"obsidian": "^1.7.2",
		"typescript": "^5.6.0"
	}
}
